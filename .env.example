# Dreamcatcher — environment variables
# Copy this file to .env and fill in your values before running locally.
# In Coolify, set these as environment variables on the application.

# Required: OpenRouter API key — the Council of LLMs talks to OpenRouter
# via the OpenAI-compatible SDK, so one key covers all three personas.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the model used by all three council members.
# Defaults to anthropic/claude-sonnet-4. Any OpenRouter model ID works.
# DREAMCATCHER_MODEL=anthropic/claude-sonnet-4
